NODE_ENV=development
PORT=3000
SERVER_BASE_URL=http://localhost:3000
APP_ORIGIN=aischedulermobile://

CORS_ORIGIN=http://localhost:8081,http://localhost:19006

MONGO_URL=mongodb://localhost:27017/schedule_automator

JWT_SECRET=
SESSION_SECRET=
ENCRYPTION_KEY=
REFRESH_TOKEN_PEPPER=
JWT_ISSUER=ai-scheduler-server
JWT_AUDIENCE=ai-scheduler-mobile
JWT_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=2592000
AUTH_HANDOFF_TTL_SECONDS=60

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=8192

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
GOOGLE_CALENDAR_AI_NAME=AI Schedule
GOOGLE_CALENDAR_EVENT_PREFIX=[AI]

APP_TIMEZONE=Asia/Seoul
WAKE_OFFSET_MINUTES=10
MAX_DAILY_WORK_MINUTES=480
DAILY_PLAN_JOB_ENABLED=true
REVIEW_REMINDER_TIME=22:30

REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=ai-scheduler:
QUEUE_NAME=ai-scheduler-jobs

LOG_LEVEL=debug
AI_PAYLOAD_LOGGING=off
MASK_SENSITIVE_LOGS=true
