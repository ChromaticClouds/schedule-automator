{
  "name": "ai-scheduler-mobile",
  "main": "index.js",
  "version": "1.0.0",
  "dependencies": {
    "@expo/ui": "~57.0.1",
    "@tanstack/react-query": "^5.101.2",
    "dayjs": "^1.11.21",
    "expo": "~57.0.1",
    "expo-constants": "~57.0.2",
    "expo-crypto": "^57.0.0",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-localization": "~57.0.0",
    "expo-notifications": "~57.0.2",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@storybook/addon-ondevice-actions": "10.4.7",
    "@storybook/addon-ondevice-backgrounds": "10.4.7",
    "@storybook/addon-ondevice-controls": "10.4.7",
    "@storybook/react-native": "10.4.7",
    "@types/react": "~19.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "storybook": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start",
    "storybook:web": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000 expo start --web --port 7007",
    "storybook:ios": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --ios",
    "storybook:android": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --android",
    "visual:capture": "cross-env VISUAL_MODE=capture playwright test",
    "visual:ci": "node ./scripts/run-visual-screenshots.mjs",
    "visual:test": "playwright test",
    "visual:update": "playwright test --update-snapshots",
    "typecheck": "tsc --noEmit",
    "validate": "node ./scripts/validate-mobile.mjs",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "private": true
}
