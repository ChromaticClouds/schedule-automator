EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=AI Scheduler
EXPO_PUBLIC_APP_SCHEME=aischedulermobile

EXPO_PUBLIC_API_BASE_URL=http://YOUR_LOCAL_IP_OR_EMULATOR_HOST:3000

EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

EXPO_PUBLIC_AI_CALENDAR_NAME=AI Schedule
EXPO_PUBLIC_AI_EVENT_PREFIX=[AI]

EXPO_PUBLIC_DEFAULT_TIMEZONE=Asia/Seoul
EXPO_PUBLIC_WAKE_OFFSET_MINUTES=10
EXPO_PUBLIC_MAX_DAILY_WORK_MINUTES=480

EXPO_PUBLIC_ENABLE_MOCK_AUTH=true
EXPO_PUBLIC_ENABLE_MOCK_CALENDAR=true
EXPO_PUBLIC_ENABLE_DEV_TOOLS=true
